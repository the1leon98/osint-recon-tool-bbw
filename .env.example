# ============================================================
# OSINT BBW Tool — Umgebungsvariablen
# Rayquaza — 2026-06-29
# ============================================================
#
# 🚨 SICHERHEITSHINWEIS:
# Diese Datei NIEMALS mit echten Keys committen!
# Sie ist eine VORLAGE — kopiere sie nach .env und fülle sie aus:
#
#     cp .env.example .env
#     nano .env
#
# .env steht in .gitignore → wird NICHT versioniert.
# .env.example steht dagegen IM Repo als Dokumentation.
#
# Prüfe vor jedem Commit:
#     git status                 → taucht .env auf? Dann SOFORT abbrechen!
#     git diff --cached          → sind echte Keys im Diff? Dann resetten!
# ============================================================


# ============================================================
# 1. LLM-Konfiguration — KOSTENLOS mit Ollama (empfohlen!)
# ============================================================
# Ollama ist VOREINGESTELLT — läuft lokal, kein API-Key nötig.
# Installation: brew install ollama && ollama pull llama3.2:3b
# Alternativ: OpenAI-Key eintragen und LLM_BASE_URL ändern.

# API-Key: Für Ollama LEER lassen! Nur für OpenAI nötig.
OPENAI_API_KEY=

# Modell: llama3.2:3b (lokal, kostenlos) oder gpt-4o-mini (OpenAI)
MODEL_NAME=llama3.2:3b

# Base-URL: Ollama = http://localhost:11434/v1 | OpenAI = https://api.openai.com/v1
LLM_BASE_URL=http://localhost:11434/v1

# ============================================================
# 3. HTTP & Request-Konfiguration
# ============================================================
# Timeout: Maximale Wartezeit pro API-Request in Sekunden.
#          Erhöhen bei großen Reports oder langsamen Proxies.
REQUEST_TIMEOUT=30
# Retries: Anzahl Wiederholungen bei Netzwerkfehlern (5xx, Timeout).
#          Wird mit exponentiellem Backoff ausgeführt.
MAX_RETRIES=3

# ============================================================
# 4. Proxy-Konfiguration (OPTIONAL)
# ============================================================
# Leer lassen für Direktzugriff.
# Für Google-Dorking: Rotierende Proxies verhindern IP-Blocking.
# Format: http://user:pass@host:port (Basic Auth) ODER http://host:port (offen)
# Mehrere: Komma-separiert, z.B. proxy1:8080,proxy2:8081
# Empfehlung: Proxy-Liste aus Umgebungsvariable PROXY_LIST laden,
#            nicht fest im Code hinterlegen.
PROXY_LIST=

# ============================================================
# 5. Logging & Debugging
# ============================================================
# DEBUG: true  → vollständige Stacktraces, Request/Response-Bodies, SQL-Logs
#        false → nur Fehlermeldungen (Produktion!).
# ⚠️  DEBUG=true kann API-Keys in Logs sichtbar machen — nie in Produktion!
DEBUG=false

# LOG_LEVEL: Steuert die Ausführlichkeit der Konsolenausgabe.
#            DEBUG   → Jeder Request, jede Sherlock-URL, jedes Dork-Ergebnis
#            INFO    → Fortschritt, Statistiken, Warnungen (empfohlen)
#            WARNING → Nur Warnungen und Fehler
#            ERROR   → Nur Fehler (minimal)
#            CRITICAL→ Nur fatale Fehler (fast stumm)
LOG_LEVEL=INFO

# ============================================================
# 6. Ausgabeverzeichnis
# ============================================================
# Pfad relativ zum Projekt-Root. Default: output/
# Enthält generierte Reports.
# Wird beim Start automatisch angelegt, falls nicht vorhanden.
OUTPUT_DIR=output

# ============================================================
# ZUSATZ: Deployment-Checkliste vor Produktionseinsatz
# ============================================================
# □ .env.example ist aktuell (neue Variablen dokumentiert)
# □ .env enthält echte Keys, NICHT in Git
# □ DEBUG=false gesetzt
# □ LOG_LEVEL=INFO oder höher
# □ OPENAI_API_KEY hat gpt-4o-mini-Zugriff
# □ PROXY_LIST ist konfiguriert oder bewusst leer
# ============================================================
